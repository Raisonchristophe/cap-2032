<!DOCTYPE html>
<html lang="fr">

<head>
  <%- include('../partial/head', { title: fiche.title }) %>
</head>

<body class="page-fiche-detail <%= pdfMode ? 'pdf-mode' : '' %>">
<% if (!pdfMode) { %>
  <%- include('../partial/nav', { currentPage: 'membre' }) %>
  <% } %>

  <!-- BREADCRUMB -->
   <% if (!pdfMode) { %>
  <div class="breadcrumb">
    <a href="/">Accueil</a>
    <span class="sep">·</span>
    <a href="/espace-membre">Espace membre</a>
    <span class="sep">·</span>
    <span><%= fiche.title %></span>
  </div>
  <% } %>

  <!-- HERO -->
  <section class="fiche-hero">

    <span class="fiche-tag">Fiche <%= id %></span>

    <h1>
      <%= fiche.title %><br>
      <em><%= fiche.subtitle %></em>
    </h1>

    <p class="fiche-intro">
      <%= fiche.intro %>
    </p>

  </section>

  <!-- CONTENU -->
  <section class="fiche-body">

    <% fiche.sections.forEach(section => { %>

      <% if (section.type === "title") { %>
        <h2><%= section.content %></h2>
      <% } %>

      <% if (section.type === "subtitle") { %>
        <h3><%= section.content %></h3>
      <% } %>

      <% if (section.type === "text") { %>
        <p><%= section.content %></p>
      <% } %>

      <% if (section.type === "list") { %>
        <ul>
          <% section.items.forEach(item => { %>
            <li><%= item %></li>
          <% }) %>
        </ul>
      <% } %>

      <% if (section.type === "quote") { %>
        <div class="pullquote">
          <%= section.content %>
        </div>
      <% } %>

<% if (section.type === "encadre") { %>

  <% if (pdfMode) { %>

    <!-- VERSION PDF (DÉCOUPÉE) -->
    <section class="bloc">
      <h2><%= section.title %></h2>

      <% section.content.split('\n\n').forEach(paragraph => { %>
        <p><%= paragraph %></p>
      <% }) %>

    </section>

  <% } else { %>

    <!-- VERSION SITE (ORIGINALE) -->
    <div class="encadre">
      <h3><%= section.title %></h3>
      <p style="white-space: pre-line;"><%= section.content %></p>
    </div>

  <% } %>

<% } %>

    <% }) %>

  </section>

  <!-- DOWNLOAD -->
   <% if (!pdfMode) { %>
  <section class="download-section">
    <a href="/download/fiche/<%= id %>" class="btn btn-primary">
      📄 Télécharger la fiche (PDF)
    </a>

    <p class="download-note">
      Version complète téléchargeable pour lecture hors ligne.
    </p>
  </section>
  <% } %>

  <!-- NAVIGATION FICHES -->
   <% if (!pdfMode) { %>
  <div class="content-nav simple">

    <% if (id > 1) { %>
      <a href="/membre/fiche/<%= id - 1 %>">
        ← Fiche précédente
      </a>
    <% } %>

    <% if (id < 15) { %>
      <a href="/membre/fiche/<%= Number(id) + 1 %>">
        Fiche suivante →
      </a>
    <% } %>

  </div>
  <% } %>

<% if (!pdfMode) { %>
  <%- include('../partial/footer') %>
  <% } %>

</body>
</html>
