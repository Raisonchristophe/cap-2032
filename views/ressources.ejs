<script>
const allResources = document.querySelectorAll('.resource');
const searchInput = document.getElementById('search');
const countLabel = document.getElementById('count-label');
const videMsg = document.getElementById('vide');

// Compter par catégorie
function updateBadges(){
  const cats = ['pilier1','pilier2','pilier3'];
  cats.forEach(cat => {
    const visible = [...allResources].filter(r => r.dataset.cat === cat && r.style.display !== 'none').length;
    const badge = document.getElementById('badge-' + cat);
    if(badge) badge.textContent = visible + ' source' + (visible > 1 ? 's' : '');
    const group = document.getElementById('group-' + cat);
    if(group) group.style.display = visible === 0 ? 'none' : 'block';
  });
  // Total
  const totalVisible = [...allResources].filter(r => r.style.display !== 'none').length;
  const totalCount = document.querySelector('.total-count');
  if(totalCount) totalCount.textContent = allResources.length;
  countLabel.textContent = totalVisible + ' ressource' + (totalVisible > 1 ? 's' : '') + ' affichée' + (totalVisible > 1 ? 's' : '');
  videMsg.style.display = totalVisible === 0 ? 'block' : 'none';
}

let currentCat = 'all';

function filter(category, btn){
  currentCat = category;
  document.querySelectorAll('.filters button').forEach(b => b.classList.remove('active'));
  if(btn) btn.classList.add('active');
  applyFilters();
}

function applyFilters(){
  const search = searchInput.value.toLowerCase();
  allResources.forEach(r => {
    const catOk = currentCat === 'all' || r.dataset.cat === currentCat;
    const searchOk = !search || r.innerText.toLowerCase().includes(search) || (r.dataset.tags || '').includes(search);
    r.style.display = (catOk && searchOk) ? 'grid' : 'none';
  });
  updateBadges();
}

searchInput.addEventListener('input', applyFilters);

// Init
updateBadges();
</script>

