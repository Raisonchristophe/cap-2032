<!DOCTYPE html>
<html lang="fr">
<head>

<%- include('partial/head', { title: "Contact — CAP 2032"}) %>

<style>
:root{
  --noir:#0d0d0d;
  --blanc:#f5f2eb;
  --ocre:#b5822a;
  --ocre-clair:#d4a85a;
  --gris:#6b6459;
  --gris-clair:#c8c0b0
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box
}

body{
  background:var(--noir);
  color:var(--blanc);
  font-family:'Source Serif 4',serif
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  padding:2rem 4rem;
  border-bottom:1px solid rgba(181,130,42,.2)
}

.nav-logo{
  font-family:'DM Mono';
  color:var(--ocre);
  text-decoration:none
}

.nav-links{
  display:flex;
  gap:2rem;
  list-style:none
}

.nav-links a{
  color:var(--gris-clair);
  text-decoration:none;
  font-family:'DM Mono'
}

.nav-links a.active{
  color:var(--ocre)
}

/* HERO */
.hero{
  padding:6rem 4rem;
  text-align:center
}

.hero h1{
  font-family:'Playfair Display';
  font-size:3rem;
  margin-bottom:1rem
}

.hero p{
  color:var(--gris-clair);
  max-width:600px;
  margin:auto
}

.contact{
  padding:4rem;
  max-width:600px;
  margin:auto
}

/* FORMULAIRE */
form{
  display:flex;
  flex-direction:column;
  gap:1rem
}

input, textarea{
  padding:12px;
  background:#111;
  border:1px solid rgba(181,130,42,.3);
  color:white;
}

button{
  background:var(--ocre);
  border:none;
  padding:12px;
  cursor:pointer;
  font-family:'DM Mono';
}

button:hover{
  background:var(--ocre-clair);
}

/* FOOTER */
    footer {
      padding: 3rem 4rem;
      border-top: 1px solid rgba(181,130,42,0.2);
      display: flex; justify-content: space-between; align-items: center;
    }

    .footer-logo {
      font-family: 'DM Mono', monospace; font-size: 0.7rem;
      letter-spacing: 0.2em; color: var(--ocre);
      text-transform: uppercase; text-decoration: none;
    }

    .footer-credit {
      font-family: 'DM Mono', monospace; font-size: 0.6rem;
      letter-spacing: 0.15em; color: var(--gris); text-transform: uppercase;
    }
</style>
</head>

<body class="page-contact">

<%- include('partial/nav', { currentPage: 'contact' }) %>

<section class="hero">
  <h1>Entrer en contact</h1>
  <p>Pour toute question, échange ou prise de contact, vous pouvez utiliser le formulaire ci-dessous.</p>
</section>

<section class="contact">

<form action="/contact" method="POST">

  <input type="text" name="nom" placeholder="Nom" required>

  <input type="email" name="email" placeholder="Email" required>

  <textarea name="message" rows="5" placeholder="Votre message..." required></textarea>

  <button type="submit">Envoyer</button>

</form>

</section>

<%- include ('partial/footer') %>

</body>
</html>
